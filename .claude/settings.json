{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "pala_note": "Conservative default. Hook enforcement remains separate until local smoke-test evidence is reviewed.",
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(node --version)",
      "Bash(npm --version)",
      "Bash(python --version)",
      "Bash(npm run pala:*)",
      "Bash(npm run check:*)",
      "Bash(npm test:*)"
    ],
    "deny": [
      "Bash(git push:*)",
      "Bash(npm publish:*)",
      "Bash(pnpm publish:*)",
      "Bash(yarn publish:*)",
      "Bash(rm -rf:*)",
      "Bash(del /s:*)",
      "Bash(rmdir /s:*)"
    ]
  }
}
